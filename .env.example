DATA_MODE=pg                # mock | pg  (defaults to pg in NODE_ENV=production)
DATABASE_URL=postgres://ntt_grc:CHANGE_ME@localhost:5432/ntt_grc_hub
ANTHROPIC_API_KEY=               # Optional — enables LLM board narrative
TSUZUMI_ENDPOINT=                # Optional — NTT Tsuzumi LLM endpoint
KNOWBE4_API_KEY=                 # Optional — enables live KnowBe4 VRO sync
KNOWBE4_REGION=us                # us | eu (KnowBe4 data centre region)
NODE_ENV=development

# SMTP (optional — password-reset emails; falls back to console.info when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="NTT GRC Hub <noreply@example.com>"
